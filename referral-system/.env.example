# Server
PORT=3001
NODE_ENV=development
MCP_TRANSPORT=stdio                    # stdio | streamable_http
LOG_LEVEL=info

# Supabase / Database
# Local dev: supabase start gives you these
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# Redis (optional for dev — system degrades gracefully without it)
REDIS_URL=redis://localhost:6379

# CRM
CRM_PROVIDER=hubspot                   # hubspot | salesforce
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# Enrichment
ENRICHMENT_PROVIDER=apollo             # apollo | clearbit
APOLLO_API_KEY=
CLEARBIT_API_KEY=

# Conversation Intelligence
CONVO_INTEL_PROVIDER=gong              # gong | fathom
GONG_API_KEY=
GONG_ACCESS_KEY_SECRET=

# Intent Data
INTENT_PROVIDER=sixsense              # sixsense | bombora
SIXSENSE_API_KEY=

# Notifications
SLACK_BOT_TOKEN=
SLACK_REFERRAL_CHANNEL=
SLACK_APPROVAL_CHANNEL=

# Feature Flags
ENABLE_ENRICHMENT=false
ENABLE_CONVO_INTEL=false
ENABLE_INTENT_DATA=false
ENABLE_SLACK_NOTIFICATIONS=false
ENABLE_AUTO_TRIGGER_SCAN=false

# Scoring Configuration
READINESS_HOT_THRESHOLD=80
READINESS_WARM_THRESHOLD=55
SUPER_REFERRER_PLATINUM_THRESHOLD=80
SUPER_REFERRER_GOLD_THRESHOLD=60
SUPER_REFERRER_SILVER_THRESHOLD=40
MAX_FOLLOW_UPS=2
ASK_COOLDOWN_DAYS=90
